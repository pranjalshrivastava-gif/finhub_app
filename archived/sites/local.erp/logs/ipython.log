2026-05-06 12:52:53,253 INFO ipython # Force setup complete in System Settings
frappe.db.set_value("System Settings", "System Settings", "setup_complete", 1)

# Force the global default
frappe.db.set_default("desktop:setup_complete", "1")

# Create a dummy company (Wizard usually fails because this is missing)
if not frappe.db.exists("Company", "My Company"):
    from erpnext.setup.setup_wizard.sample_data import setup_company
    setup_company("My Company", "USD")

# Commit changes and exit
frappe.db.commit()
exit()
