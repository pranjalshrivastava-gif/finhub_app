2026-05-06 12:52:53,253 INFO ipython # 1. Mark system settings as complete
frappe.db.set_value("System Settings", "System Settings", "setup_complete", 1)

# 2. Set global defaults to bypass wizard
frappe.db.set_default("desktop:setup_complete", "1")
frappe.db.set_default("setup_complete", "1")

# 3. Create a basic Company (Manual version to avoid import errors)
if not frappe.db.exists("Company", "My Company"):
    doc = frappe.get_doc({
        "doctype": "Company",
        "company_name": "My Company",
        "default_currency": "USD",
        "country": "United States" 
    })
    doc.insert(ignore_permissions=True)

# 4. Commit and Exit
frappe.db.commit()
exit()
2026-05-06 12:52:53,253 INFO ipython # 1. Enable Server Scripts at the session level just in case
frappe.flags.ignore_server_script = True

